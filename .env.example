# 火山引擎 (Volcengine Ark) 凭证
VOLC_ACCESS_KEY=your_volc_access_key
VOLC_SECRET_KEY=your_volc_secret_key
# 剪辑脚本生成 LLM Endpoint ID
# 推荐使用 DeepSeek-V3 (创意更强) 或 Doubao-pro-128k (更稳定)
# 在火山引擎控制台创建对应模型的推理接入点，将 endpoint ID 填入下方
DOUBAO_ENDPOINT_ID=your_endpoint_id
# 视频理解算子 Endpoint ID (ArkLLMVisionUnderstanding)
VISION_ENDPOINT_ID=your_vision_endpoint_id

# -------- Image2Excel service --------
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=temp_uploads
OUTPUT_DIR=outputs
LLM_PROVIDER_NAME=volcengine
LLM_API_KEY=your_llm_api_key
LLM_MODEL_NAME=your_llm_model_name
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
LLM_TIMEOUT=240
LOG_LEVEL=INFO
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=image2excel
DB_PARAMS=charset=utf8mb4
WRITE_ALLOWED_IPS=127.0.0.1,::1,localhost
INVENTORY_ALERT_POPUP_ENABLED=true
INVENTORY_ALERT_OPENCLAW_ENABLED=false
INVENTORY_ALERT_OPENCLAW_WEBHOOK_URL=
INVENTORY_ALERT_FEISHU_WEBHOOK_URL=